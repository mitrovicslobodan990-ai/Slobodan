# Firebase Admin SDK Service Account JSON Path
# This should point to your Firebase service account key file
# On Render, this will be set via Environment Variables (secrets)
# locally, you can set this to the full path of your service account file
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/your/serviceAccountKey.json

# Server port
# Default: 3000
PORT=3000

# Node environment
# Options: development, production
NODE_ENV=production
